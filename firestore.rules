rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mehedyhossain160619@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 &&
             data.purchase_price is number && data.purchase_price >= 0 &&
             data.selling_price is number && data.selling_price >= 0 &&
             data.profit_margin is number &&
             data.quantity is number &&
             (!('ram' in data) || data.ram is string) &&
             (!('rom' in data) || data.rom is string) &&
             data.created_at is string;
    }

    function isValidSale(data) {
      return data.customer_name is string && data.customer_name.size() > 0 &&
             data.phone_number is string &&
             data.nid_number is string &&
             data.address is string &&
             (!('guarantor_number' in data) || data.guarantor_number is string) &&
             data.product_id is string &&
             data.product_name is string &&
             (!('ram' in data) || data.ram is string) &&
             (!('rom' in data) || data.rom is string) &&
             data.image_file_ids is list &&
             data.sale_date is string &&
             data.profit is number;
    }

    function isValidMobileBazar(data) {
      return data.sale_id is string &&
             data.customer_name is string &&
             data.product_name is string &&
             (!('ram' in data) || data.ram is string) &&
             (!('rom' in data) || data.rom is string) &&
             data.down_payment is number &&
             data.sale_profit is number &&
             data.net_amount is number &&
             data.created_at is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /mobile_bazar/{recordId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMobileBazar(request.resource.data);
      allow update, delete: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
